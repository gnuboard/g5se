{
  "name": "gnu5se-tailwind-build",
  "version": "1.0.0",
  "description": "Tailwind v4 build for theme/tailwind. Output → ../../app/theme/tailwind/css/tailwind.css",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i input.css -o ../../app/theme/tailwind/css/tailwind.css --minify",
    "watch": "tailwindcss -i input.css -o ../../app/theme/tailwind/css/tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
