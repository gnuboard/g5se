{
  "name": "gnu5se-admin-tailwind-build",
  "version": "1.0.0",
  "description": "Tailwind v4 build for app/admin. Output → ../../app/admin/css/tailwind.css",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i input.css -o ../../app/admin/css/tailwind.css --minify",
    "watch": "tailwindcss -i input.css -o ../../app/admin/css/tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
