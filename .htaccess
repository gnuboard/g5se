RewriteEngine On
Options -Indexes +FollowSymLinks

RewriteRule (^|/)\.git(?:/|$) - [F,L,NC]

# 1) PHP 직접 접근 차단 — 정적자산 폴더 + 라이브러리 폴더 안의 .php 는 절대 실행되면 안 됨
#    plugin/ 은 캡차·결제·소셜로그인·본인확인 등 외부 호출이 필요한 first-party 엔드포인트가 들어있어 차단 대상에서 제외
RewriteRule ^(theme|skin|extend|lib|js|css|img)/.+\.(php|phtml|phar)$ - [F,L]

# 2) /app/* 직접접근 전면 차단
RewriteRule ^app(/|$) - [F,L]

# 3) data/ 안에서 PHP/스크립트/HTML 실행 차단 (업로드 우회 방지)
RewriteRule ^data/.+\.(php|phtml|phar|html?|cgi|pl|py|jsp|asp|sh)$ - [F,L]
# 3.1) data/modules/ 안의 모듈 DB·내부 데이터 직접 접근 차단
RewriteRule ^data/modules/ - [F,L]

# 4) 정적 자산 폴더는 app/ 밑 실제 위치로 내부 매핑 (URL 은 root 기준)
#    data/ 는 app 밖으로 분리되어 docroot 에 직접 존재하므로 매핑 대상에서 제외
#    /adm 와 /adm/* 는 모던 /admin 으로 외부 redirect (사용자가 봐야 할 admin 은 /admin 한 곳)
RewriteRule ^adm/?$ /admin [R=301,L]
RewriteRule ^adm/(.*)$ /admin/$1 [R=301,L]
RewriteRule ^(theme|skin|img|js|css|plugin)/(.*)$ app/$1/$2 [END]

#    모던 admin 의 정적 자산: /admin/(css|js|img)/... → app/admin/$1/$2
#    (.php 컨트롤러는 front controller 가 처리해야 하므로 정적 자산만 매핑)
RewriteRule ^admin/(css|js|img)/(.*)$ app/admin/$1/$2 [END]

#    shop 정적 자산: /shop/(img|css|js)/... → app/shop/$1/$2
RewriteRule ^shop/(img|css|js)/(.*)$ app/shop/$1/$2 [END]

#    설치 마법사 — /install/* → app/install/* (front controller 우회 —
#    install 단계엔 라우팅/세션/DB 가 아직 없음)
RewriteRule ^install$ %{REQUEST_URI}/ [R=301,L,NE]
RewriteRule ^install/$ app/install/index.php [END]
# .php 명시적 (legacy form submit 등) — 그대로 매핑
RewriteRule ^install/([a-zA-Z][a-zA-Z0-9_]*)\.php$ app/install/$1.php [END]
# 하위 디렉토리 배포에서도 동작해야 하는 설치 단계 클린 URL
RewriteRule ^install/(install_config|install_db)/?$ app/install/$1.php [END]
# 클린 URL — 실제 .php 파일 있으면 매핑 (예: /install/install_config → install_config.php)
RewriteCond %{DOCUMENT_ROOT}/app/install/$1.php -f
RewriteRule ^install/([a-zA-Z][a-zA-Z0-9_]*)/?$ app/install/$1.php [END]
# 정적 자산 (img/, .css 등)
RewriteRule ^install/(.+)$ app/install/$1 [END]

# 5) 실제 파일/디렉토리는 그대로 (favicon, robots.txt 등)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 6) 그 외 모든 URL → 프런트 컨트롤러
RewriteRule ^ index.php [QSA,L]

# 7) 민감 파일 차단
<FilesMatch "(^\.|composer\.(json|lock)$|\.env$|\.git$|\.md$|\.sql$|\.log$)">
    Require all denied
</FilesMatch>
